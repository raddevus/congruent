<Window xmlns="https://github.com/avaloniaui"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      x:Class="congruent.Views.AddFolderMsgBox"
        Width="300" Height="215"
        WindowStartupLocation="CenterOwner"
        Title="Create New Folder"
        CanResize="False">
    <StackPanel Margin="10">
        <TextBlock x:Name="MessageText" TextWrapping="Wrap" Margin="0,0,0,10"/>

         <TextBlock Margin="10">Folder Name</TextBlock>
         <TextBox Name="FolderNameTB" Margin="0 5" Text=""/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
            <Button Content="OK" IsDefault="True" Click="Ok_Click"/>
            <Button Content="Cancel" IsCancel="True" Click="Cancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
